{
  "name": "docker-utils",
  "projectType": "library",
  "sourceRoot": "libs/docker-utils/src",
  "tags": ["type:lib", "lang:ts"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "dependsOn": ["^build"],
      "cache": true,
      "options": {
        "command": "npx tsdown",
        "cwd": "{projectRoot}"
      }
    }
  }
}
