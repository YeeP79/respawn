# --- Respawn: Counter-Strike 2 Server ---

# Service identity
SERVICE_NAME=cs2
SERVICE_DISPLAY_NAME="Counter-Strike 2 Server"

# Image (upstream cm2network — env-var driven, no local build/wrapper needed).
# Verified tag on Docker Hub. Source 2 dedicated server.
IMAGE_URI=cm2network/cs2:latest

# Container resources (2 vCPU / 4 GB — Source 2 is heavier than GoldSrc/Source 1)
CPU=2048
MEMORY=4096

# Primary port (game traffic + query, UDP)
CONTAINER_PORT=27015
HOST_PORT=27015
PROTOCOL=UDP
# RCON (27015/tcp), client port (27005/udp), SourceTV (27020/udp, only if TV_ENABLE=1)
ADDITIONAL_PORTS=27015/tcp,27005/udp,27020/udp

# Persistent storage (EFS) — REQUIRED. The SteamCMD install is ~60 GB and lives at
# /home/steam/cs2-dedicated. Without EFS the full download re-runs on every cold
# start (including every idle-shutdown wake), which is unworkable at this size.
ENABLE_PERSISTENT_STORAGE=true
PERSISTENT_MOUNT_PATH=/home/steam/cs2-dedicated

# Idle shutdown — scales the service to 0 after N idle minutes to save cost.

ENABLE_IDLE_SHUTDOWN=true
# GoldSrc/Source serve every client from one unconnected UDP socket, so the
# netstat check never sees players. Ask the game instead (A2S_INFO).
IDLE_CHECK_METHOD=a2s
IDLE_TIMEOUT_MINUTES=30

# Gamemode — chosen at deploy time via the CLI per-service prompt (AGENT_PROMPT.md §2).
# The chosen value overrides GAME_ENV_CS2_GAMEALIAS below; non-interactive/CI deploys
# skip the prompt and use that default.
DEPLOY_PROMPTS=CS2_GAMEALIAS:select:competitive|casual|deathmatch|wingman

# Secrets — injected as ECS secrets, not plaintext (AGENT_PROMPT.md §7).
# SRCDS_TOKEN (GSLT) is MANDATORY — CS2 will not start without it.
#
#   Where to get it: https://steamcommunity.com/dev/managegameservers
#   Use AppID 730 (Counter-Strike 2). You need a Steam account in good standing.
#
# Store both values, then deploy:
#   pnpm respawn  ->  Secrets  ->  cs2  ->  SRCDS_TOKEN, CS2_RCONPW
# The container env-var names (SRCDS_TOKEN / CS2_RCONPW) are read directly by the
# cm2network image.
SECRET_REFS=SRCDS_TOKEN=ssm:/respawn/cs2/gslt,CS2_RCONPW=sm:respawn/cs2/rcon

# Required values — checked at deploy time (preflight), before any image build or
# CloudFormation call. CS2 will not start without a GSLT, so a missing one is a
# hard failure rather than a silently unlisted server.
REQUIRED_ENV_VARS=SRCDS_TOKEN,CS2_RCONPW

# --- Game-specific environment variables (GAME_ENV_ prefix is stripped) ---
# Consumed directly by the cm2network CS2 image (see its README for the full list).
GAME_ENV_CS2_SERVERNAME="Respawn CS2"
GAME_ENV_CS2_MAXPLAYERS=10
GAME_ENV_CS2_GAMEALIAS=competitive
GAME_ENV_CS2_MAPGROUP=mg_active
GAME_ENV_CS2_STARTMAP=de_inferno
# Low-CPU state when empty (idle-shutdown still scales to 0; this softens the wait)
GAME_ENV_CS2_SERVER_HIBERNATE=1
# Optional: server password, SourceTV, workshop map/collection
# GAME_ENV_CS2_PW=
# GAME_ENV_TV_ENABLE=1
# GAME_ENV_CS2_HOST_WORKSHOP_COLLECTION=

# AWS
AWS_REGION=us-east-1
AWS_PROFILE=respawn
