# --- Respawn: 7 Days to Die Server ---

# Service identity
SERVICE_NAME=7dtd
SERVICE_DISPLAY_NAME="7 Days to Die Server"

# Image (upstream — no local build needed)
IMAGE_URI=vinanrra/7dtd-server:latest

# Container resources (7D2D is resource-heavy — voxel world + zombies)
# 2 vCPU / 8 GB is recommended minimum for a small server (4-8 players).
# Scale up to 4096 CPU / 16384 MEMORY for larger player counts or big worlds.
CPU=2048
MEMORY=8192

# Primary port (game traffic)
CONTAINER_PORT=26900
HOST_PORT=26900
PROTOCOL=UDP
# TCP 26900 = game, UDP 26901-26902 = additional game ports,
# TCP 8080 = web control panel, TCP 8081 = telnet
ADDITIONAL_PORTS=26900/tcp,26901/udp,26902/udp,8080/tcp,8081/tcp

# Persistent storage (EFS — server files, world saves, backups)
# CRITICAL: First startup downloads ~15 GB of game files via SteamCMD.
# Without persistent storage, this download repeats on every container restart.
# World saves, server config, and backups also live here.
ENABLE_PERSISTENT_STORAGE=true
PERSISTENT_MOUNT_PATH=/home/sdtdserver

# Game environment variables (GAME_ENV_ prefix is stripped)
# START_MODE: 1=start, 2=update+start, 3=update+validate+start, 4=backup+start
GAME_ENV_START_MODE=1
# VERSION: "stable" for latest stable, or a specific build number
GAME_ENV_VERSION=stable
GAME_ENV_PUID=1000
GAME_ENV_PGID=1000
# Automatic backups (latest 5 kept, runs at 5 AM server time)
GAME_ENV_BACKUP=YES
# Auto-restart if server crashes
GAME_ENV_MONITOR=YES
GAME_ENV_TimeZone=America/New_York

# --- Optional: Mods ---
# GAME_ENV_ALLOC_FIXES=YES
# GAME_ENV_CPM=YES
# GAME_ENV_UNDEAD_LEGACY=NO
# GAME_ENV_DARKNESS_FALLS=NO

# Idle shutdown — netstat-based on game port
ENABLE_IDLE_SHUTDOWN=true
# 7 Days to Die is Steam-hosted and answers A2S on the game port.
# UNVERIFIED against a live server — a wrong port reports "unknown", which
# holds the idle timer (server never scales down) rather than killing a game.
IDLE_CHECK_METHOD=a2s
IDLE_QUERY_PORT=26900
IDLE_TIMEOUT_MINUTES=30

# --- Prerequisites ---
# 1. No game files needed upfront — SteamCMD downloads everything on first boot.
#    First startup will take 10-15 minutes depending on network speed.
#
# 2. After first boot, edit server settings in the EFS volume at:
#    /home/sdtdserver/serverfiles/sdtdserver.xml
#
# 3. The web control panel (port 8080) and telnet (port 8081) are optional.
#    Configure passwords for these in sdtdserver.xml before exposing publicly.

# --- Server name ---
# The vinanrra image exposes no env var for it: 7 Days to Die reads its server
# name from ServerName in sdtdserver.xml, on the EFS volume at
# /home/sdtdserver/serverfiles/sdtdserver.xml. Edit it after the first boot,
# then restart the service.

# Update checks — `pnpm respawn:check-updates` compares these against the
# values recorded at the last deploy (SSM: /respawn/<svc>/state/...).
# vinanrra installs 7DTD via SteamCMD at container start.
UPDATE_CHECK=image,steam:294420
