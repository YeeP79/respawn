{
  "name": "respawn-mcp",
  "projectType": "application",
  "sourceRoot": "apps/respawn-mcp/src",
  "tags": [
    "type:app",
    "lang:ts"
  ],
  "targets": {
    "build": {
      "dependsOn": [
        "generate-manifests",
        "^build"
      ],
      "inputs": [
        "default",
        "^default",
        "gameManifests"
      ],
      "outputs": [
        "{projectRoot}/dist"
      ],
      "cache": true,
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsdown",
        "cwd": "{projectRoot}"
      }
    },
    "generate-manifests": {
      "cache": true,
      "inputs": [
        "{projectRoot}/generate-manifests.mjs",
        "{projectRoot}/src/manifest.ts",
        "gameManifests"
      ],
      "outputs": [
        "{projectRoot}/src/manifests.generated.ts"
      ],
      "executor": "nx:run-commands",
      "options": {
        "command": "node --experimental-strip-types apps/respawn-mcp/generate-manifests.mjs",
        "cwd": "{workspaceRoot}"
      }
    },
    "typecheck": {
      "dependsOn": [
        "generate-manifests"
      ],
      "inputs": [
        "default",
        "^default",
        "gameManifests"
      ]
    },
    "test": {
      "dependsOn": [
        "generate-manifests"
      ],
      "inputs": [
        "default",
        "^default",
        "gameManifests"
      ]
    },
    "lint": {
      "dependsOn": [
        "generate-manifests"
      ],
      "inputs": [
        "default",
        "^default",
        "gameManifests"
      ]
    }
  }
}
