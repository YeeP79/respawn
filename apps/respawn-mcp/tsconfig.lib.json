{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "composite": false,
    "declaration": false,
    "emitDeclarationOnly": false,
    "noEmit": false,
    "module": "nodenext",
    "types": [
      "node"
    ],
    "declarationMap": false,
    "importHelpers": false,
    "rootDir": "src"
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ]
}
