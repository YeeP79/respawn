# --- Respawn: Quake 3 Arena Server ---

# Service identity
SERVICE_NAME=quake3
SERVICE_DISPLAY_NAME="Quake 3 Arena Server"

# Image (upstream — no local build needed)
IMAGE_URI=inanimate/quake3:latest

# Container resources (ioquake3 is very lightweight)
CPU=256
MEMORY=512

# Primary port (game traffic)
CONTAINER_PORT=27960
HOST_PORT=27960
PROTOCOL=UDP

# Persistent storage (EFS — for pak0.pk3 and server.cfg)
# You MUST place pak0.pk3 (from your Quake 3 Arena retail install) on the EFS
# volume before starting the server. Typical locations:
#   Steam (Linux): ~/.local/share/Steam/steamapps/common/Quake 3 Arena/baseq3/pak0.pk3
#   Steam (Windows): C:\Program Files (x86)\Steam\steamapps\common\Quake 3 Arena\baseq3\pak0.pk3
#   GOG: check install directory under baseq3/
#
# Optionally place a server.cfg file alongside it to customize server settings
# (map rotation, fraglimit, timelimit, bot config, RCON password, etc.).
# See: https://github.com/InAnimaTe/docker-quake3 for server.cfg examples.
ENABLE_PERSISTENT_STORAGE=true
PERSISTENT_MOUNT_PATH=/usr/share/games/quake3/baseq3

# Idle shutdown — netstat-based
ENABLE_IDLE_SHUTDOWN=true
# idTech3 `getstatus` on the game port.
IDLE_CHECK_METHOD=q3
IDLE_TIMEOUT_MINUTES=30

# --- Server name ---
# Set with `seta sv_hostname "Your Name"` in the server.cfg you upload to the EFS
# volume alongside pak0.pk3 (/usr/share/games/quake3/baseq3/). The image takes no
# env var for it. See https://github.com/InAnimaTe/docker-quake3 for a sample cfg.
