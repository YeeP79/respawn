{
  "displayName": "Quake 3 Arena",
  "engine": "idtech3",
  "notes": "idTech3 rcon (one connectionless UDP packet). Command forms are the standard Q3 console; not yet verified against a live server. rcon requires rconpassword set on the server.",
  "maps": ["q3dm1", "q3dm6", "q3dm7", "q3dm17", "q3tourney2", "q3ctf1", "q3ctf2"],
  "commands": [
    { "name": "change_map", "description": "Load a map (e.g. q3dm6, q3dm17).", "rcon": "map {map}", "args": { "map": {} } },
    { "name": "next_map", "description": "Advance to the next map in rotation.", "rcon": "vstr nextmap" },
    { "name": "kick_player", "description": "Kick a player by name.", "rcon": "kick {player}", "args": { "player": {} }, "danger": true },
    { "name": "kick_all", "description": "Kick every connected player.", "rcon": "kick allbots", "danger": true },
    { "name": "add_bot", "description": "Add a bot (e.g. sarge) at a skill 1–5.", "rcon": "addbot {name} {skill}", "args": { "name": {}, "skill": { "values": ["1", "2", "3", "4", "5"] } } },
    { "name": "set_cvar", "description": "Set any server cvar.", "rcon": "set {cvar} {value}", "args": { "cvar": {}, "value": {} } },
    { "name": "say", "description": "Broadcast a message to everyone.", "rcon": "say {message}", "args": { "message": {} } }
  ],
  "queries": [
    {
      "name": "players",
      "description": "Connected players from the idTech3 statusResponse (name and score per row).",
      "rcon": "status",
      "singles": { "map": "mapname\\\\([^\\\\]+)", "hostname": "sv_hostname\\\\([^\\\\]+)" },
      "row": { "match": "^(\\d+)\\s+(\\d+)\\s+\"([^\"]*)\"", "fields": ["score", "ping", "name"] }
    }
  ],
  "cvars": [
    { "name": "timelimit", "description": "Minutes per map (0 = none).", "default": "0", "range": [0, 120] },
    { "name": "fraglimit", "description": "Frags to end the map.", "default": "20", "range": [0, 1000] },
    { "name": "g_gametype", "description": "0 FFA, 1 Tournament, 3 TDM, 4 CTF.", "default": "0", "values": ["0", "1", "3", "4"] },
    { "name": "bot_minplayers", "description": "Fill to this many players with bots.", "default": "0", "range": [0, 16] },
    { "name": "g_gravity", "description": "World gravity.", "default": "800", "range": [0, 2000] }
  ]
}
