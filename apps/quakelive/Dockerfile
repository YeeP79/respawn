FROM dpadgett/ql-docker:latest

# The base image bundles the standard minqlx-plugins (essentials, ban, motd, etc.)
# To add custom plugins, uncomment and adjust:
#
# COPY my_plugin.py /home/qlserver/minqlx-plugins/
#
# Then remove IMAGE_URI from .env so respawn builds from this Dockerfile instead.
# Add the plugin name to GAME_ENV_qlx_plugins in .env to load it on boot.
