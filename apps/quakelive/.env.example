# --- Respawn: Quake Live Server ---

# Service identity
SERVICE_NAME=quakelive
SERVICE_DISPLAY_NAME="Quake Live Server"

# Image (upstream — no local build needed)
IMAGE_URI=dpadgett/ql-docker:latest

# Container resources (Quake Live is lightweight)
CPU=256
MEMORY=512

# Primary port (game traffic)
CONTAINER_PORT=27960
HOST_PORT=27960
PROTOCOL=UDP
# TCP 27960 = stats, TCP 28960 = RCON
ADDITIONAL_PORTS=27960/tcp,28960/tcp

# Redis sidecar (required for minqlx plugins — map votes, ELO, etc.)
# Adds a redis:7-alpine container to the Fargate task definition.
# Set to false if you don't need minqlx plugins; the base server still works.
ENABLE_REDIS_SIDECAR=true

# Game environment variables (GAME_ENV_ prefix is stripped)
# Server display name
GAME_ENV_name=Respawn Quake Live
# Steam64 ID of the server admin — grants automatic RCON access.
# Find your Steam64 ID at https://steamid.io/
GAME_ENV_admin=changeme
# Point minqlx to the Redis sidecar (same task, shared network namespace)
GAME_ENV_qlx_redisAddress=localhost:6379
# Plugins to load on boot (comma-separated). These ship with the image.
# Full list: https://github.com/MinoMino/minqlx-plugins
# Community plugins: https://github.com/MinoMino/minqlx/wiki/Useful-Plugins
GAME_ENV_qlx_plugins=plugin_manager, essentials, motd, permission, ban, silence, clan, names, log, workshop

# Idle shutdown — netstat-based
ENABLE_IDLE_SHUTDOWN=true
IDLE_CHECK_METHOD=netstat
IDLE_TIMEOUT_MINUTES=30

# --- Prerequisites ---
# 1. Quake Live is free-to-play on Steam. The server downloads game files via
#    SteamCMD automatically on first start.
#
# 2. The image bundles minqlx (plugin framework) which requires a Redis
#    container for persistent data (map votes, ELO, etc.). The Redis sidecar
#    is enabled by default via ENABLE_REDIS_SIDECAR=true above.
#
# 3. Set GAME_ENV_admin to your Steam64 ID for RCON access in-game.
#
# --- Adding Custom Plugins ---
# The standard minqlx plugins are bundled in the image. To add custom plugins:
#   1. Place the .py file(s) in apps/quakelive/
#   2. Uncomment the COPY line in the Dockerfile
#   3. Remove IMAGE_URI from .env (so respawn builds from Dockerfile instead)
#   4. Add the plugin name to GAME_ENV_qlx_plugins above
#
# Find community plugins at:
#   https://github.com/MinoMino/minqlx/wiki/Useful-Plugins
#   https://github.com/BarelyMiSSeD/minqlx-plugins
