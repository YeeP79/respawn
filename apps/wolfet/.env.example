# --- Respawn: Wolfenstein: Enemy Territory (ET: Legacy engine) ---
# Service identity
SERVICE_NAME=wolfet
SERVICE_DISPLAY_NAME="Wolfenstein: Enemy Territory Server"

# Image: built locally from this app's Dockerfile (etlegacy/server + Respawn shim).
# IMAGE_URI is intentionally unset — etlded is config-file driven, so the rcon
# password cannot be passed on the command line without landing in the ECS task
# definition. respawn-init.sh writes it into an overlay cfg instead.

# Container resources. Generous first-boot sizing; ET: Legacy is a light idTech3
# server, so right-size down after measuring with container_stats under real load.
CPU=512
MEMORY=1024

# Primary port — idTech3 serves game traffic AND connectionless rcon on one UDP port.
CONTAINER_PORT=27960
HOST_PORT=27960
PROTOCOL=UDP

# Idle shutdown — scales the service to 0 after N idle minutes to save cost.
# idTech3 answers `getstatus`, so the watchdog can ask the game directly.
ENABLE_IDLE_SHUTDOWN=true
IDLE_CHECK_METHOD=q3
IDLE_TIMEOUT_MINUTES=30

# rcon-control sidecar — reachable ONLY via `aws ecs execute-command` (SSM), no
# inbound port of its own. It speaks idTech3 rcon over loopback to the game port.
# NOTE: idTech3 rcon rides the public game port (27960), gated solely by the
# password — so a strong rconpassword is the only thing protecting it. This is
# inherent to the engine (same as quake3), not a Respawn choice.
ENABLE_RCON_CONTROL=true
RCON_PROTOCOL=q3
RCON_PORT=27960

# Secret — injected as an ECS secret, not plaintext (AGENT_PROMPT.md §7).
# respawn-init.sh reads RCON_PASSWORD and writes `set rconpassword` into the overlay
# cfg. Resolved by the ECS agent before the container starts, so create it first:
#   pnpm respawn -> Secrets -> wolfet   (sm:respawn/wolfet/rcon)
SECRET_REFS=RCON_PASSWORD=sm:respawn/wolfet/rcon

# --- Game-specific environment variables (GAME_ENV_ prefix is stripped) ---
# Consumed by respawn-init.sh: SERVERNAME -> sv_hostname.
GAME_ENV_SERVERNAME="Respawn Enemy Territory"

# Persistent storage is OFF for the first cut. To keep custom maps (.pk3) and logs
# across restarts, mount the engine's homepath — NOT etmain, which would shadow the
# image's stock etl_server.cfg with an empty EFS volume and break the server:
#   ENABLE_PERSISTENT_STORAGE=true
#   PERSISTENT_MOUNT_PATH=/legacy/homepath
ENABLE_PERSISTENT_STORAGE=false

# Update checks — `pnpm respawn:check-updates` compares against the values recorded
# at the last deploy. This service builds its own image, so track the build.
UPDATE_CHECK=build
