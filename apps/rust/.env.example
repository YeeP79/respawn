# --- Respawn: Rust Server ---

# Service identity
SERVICE_NAME=rust
SERVICE_DISPLAY_NAME="Rust Server"

# Image (upstream — no local build needed)
IMAGE_URI=didstopia/rust-server:latest

# Container resources — Rust is the heaviest server in the fleet.
# RAM scales with map size + population:
#   ~3500 map / 50 players  -> 16384 (16 GB) is comfortable
#   ~4500 map / 100+ players -> bump to 30720 (30 GB, the Fargate ceiling at 4 vCPU)
# NOTE: CPU/memory are fixed per deploy. To give it more muscle, edit these and
# redeploy — the container restarts but the world is safe on EFS (see wipe notes).
CPU=4096
MEMORY=16384

# Primary port (game traffic, UDP)
CONTAINER_PORT=28015
HOST_PORT=28015
PROTOCOL=UDP
# RCON (28016/tcp, web RCON websocket), Steam query (28017/udp), Rust+ companion app (28082/tcp)
ADDITIONAL_PORTS=28017/udp,28082/tcp
# Admin ports — NOT publicly exposed (Rust RCON; admin only).
# Declared on the task (loopback-reachable by the rcon-control sidecar) but
# the security group opens no ingress for them.
INTERNAL_PORTS=28016/tcp

# Persistent storage (EFS) — REQUIRED.
# Holds the SteamCMD game files (~8 GB), the procedural map, and all save data.
# Without this, the full download + a fresh map happen on every restart.
ENABLE_PERSISTENT_STORAGE=true
PERSISTENT_MOUNT_PATH=/steamcmd/rust

# Idle shutdown — scales the service to 0 after N idle minutes to save cost.
# NOTE: netstat detection counts established sockets on the game port. Rust is
# UDP-based, so verify it registers live players after first deploy; if it scales
# down with players connected, raise IDLE_TIMEOUT_MINUTES or disable.
ENABLE_IDLE_SHUTDOWN=true
# Rust answers Steam queries on its query port (28017), not the game port.
IDLE_CHECK_METHOD=a2s
IDLE_QUERY_PORT=28017
IDLE_TIMEOUT_MINUTES=30

# --- Game environment variables (GAME_ENV_ prefix is stripped) ---

# World identity — the save directory name. Changing this starts a brand-new world.
GAME_ENV_RUST_SERVER_IDENTITY=respawn
GAME_ENV_RUST_SERVER_NAME="Respawn Rust"
GAME_ENV_RUST_SERVER_DESCRIPTION="Respawn Rust server"
GAME_ENV_RUST_SERVER_MAXPLAYERS=50

# Map generation — seed + worldsize define the map.
# Changing EITHER value regenerates the map = a MAP WIPE on next (re)deploy.
GAME_ENV_RUST_SERVER_SEED=12345
GAME_ENV_RUST_SERVER_WORLDSIZE=3500

# RCON (used for remote admin / wipes / player counts)
GAME_ENV_RUST_RCON_PORT=28016
GAME_ENV_RUST_RCON_WEB=1
# RCON password — injected as an ECS secret, not plaintext (see AGENT_PROMPT.md §7).
# Set the value with the Secrets CLI action, then reference it here:
SECRET_REFS=RUST_RCON_PASSWORD=sm:respawn/rust/rcon-password

# Steam query port (kept distinct from RCON's default 28016)
GAME_ENV_RUST_SERVER_QUERYPORT=28017

# --- Update / wipe control (manual wipes) ---
# RUST_START_MODE: 0 = update + start, 1 = update only, 2 = start only (NO update)
# RUST_UPDATE_CHECKING: 1 = background watcher auto-updates (and can force a wipe); 0 = off
#
# DEFAULT below = update on start, no background auto-updates. Normal restarts
# (including idle wake-ups) just validate files; no wipe. The ONLY time updating
# forces a wipe is Facepunch's monthly map update (first Thursday).
#
# To LOCK an extended game across a forced-wipe week:
#   set RUST_START_MODE=2 and redeploy before the first Thursday. The build is
#   frozen, so no update and therefore no forced map wipe — the world persists
#   indefinitely across restarts. Switch back to 0 and redeploy when you choose
#   to update + wipe on your own schedule.
#
# To perform a MANUAL wipe at a time of your choosing, do either:
#   (a) bump GAME_ENV_RUST_SERVER_SEED (and/or WORLDSIZE) and redeploy -> fresh map, or
#   (b) clear the save dir on EFS under /steamcmd/rust/server/<identity>/ and redeploy.
GAME_ENV_RUST_START_MODE=0
GAME_ENV_RUST_UPDATE_CHECKING=0


# Update checks — `pnpm respawn:check-updates` compares these against the
# values recorded at the last deploy (SSM: /respawn/<svc>/state/...).
# didstopia installs Rust via SteamCMD at container start.
UPDATE_CHECK=image,steam:258550

# AWS
AWS_ACCOUNT_ID=847378615943
AWS_REGION=us-east-1
AWS_PROFILE=respawn
