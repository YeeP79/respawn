# --- Respawn: Doom 2 Server (Zandronum) ---

# Service identity
SERVICE_NAME=doom2
SERVICE_DISPLAY_NAME="Doom 2 Server"

# Image (upstream — no local build needed)
IMAGE_URI=rcdailey/zandronum-server:official-latest

# Container resources (Zandronum is extremely lightweight)
CPU=256
MEMORY=512

# Primary port (game traffic)
CONTAINER_PORT=10666
HOST_PORT=10666
PROTOCOL=UDP

# Persistent storage (EFS — for WAD files)
# Place doom2.wad (from your Doom 2 install) or freedoom2.wad (free alternative)
# on the EFS volume at /data/ before starting the server.
# Freedoom: https://freedoom.github.io/
ENABLE_PERSISTENT_STORAGE=true
PERSISTENT_MOUNT_PATH=/data

# Container command (Zandronum uses CLI args, not env vars for game config)
# Adjust -iwad, map, skill, and player count to taste.
# Skill levels: 1=ITYTD, 2=HNTR, 3=HMP, 4=UV, 5=Nightmare
CONTAINER_COMMAND=-iwad /data/doom2.wad -port 10666 +sv_hostname "Respawn Doom 2" +sv_maxplayers 16 +sv_maxclients 16 +skill 3 +map MAP01 +sv_maprotation true

# Game environment variables (GAME_ENV_ prefix is stripped)
GAME_ENV_ZANDRONUM_UID=1000
GAME_ENV_ZANDRONUM_GID=1000

# Idle shutdown — probes Zandronum's launcher protocol (Huffman-coded).
# Verified against a live server. The probe reports the server's query flood
# protection (sv_queryignoretime) as "unknown", never as "empty", so a
# rate-limited reply can never be mistaken for an empty server.
ENABLE_IDLE_SHUTDOWN=true
IDLE_CHECK_METHOD=zandronum
IDLE_TIMEOUT_MINUTES=30
