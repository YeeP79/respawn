# --- Respawn: Doom 2 Server (Zandronum) ---

# Service identity
SERVICE_NAME=doom2
SERVICE_DISPLAY_NAME="Doom 2 Server"

# Image (upstream — no local build needed)

# Container resources (Zandronum is extremely lightweight)
CPU=256
MEMORY=512

# Primary port (game traffic)
CONTAINER_PORT=10666
HOST_PORT=10666
PROTOCOL=UDP

# Persistent storage (EFS — for WAD files)
# Place doom2.wad (from your Doom 2 install) or freedoom2.wad (free alternative)
# on the EFS volume at /data/ before starting the server.
# Freedoom: https://freedoom.github.io/
ENABLE_PERSISTENT_STORAGE=true
PERSISTENT_MOUNT_PATH=/data

# Container command (Zandronum uses CLI args, not env vars for game config)
# Adjust -iwad, map, skill, and player count to taste.
# Skill levels: 1=ITYTD, 2=HNTR, 3=HMP, 4=UV, 5=Nightmare
CONTAINER_COMMAND=-port 10666 +sv_hostname "Respawn Doom 2" +sv_maxplayers 16 +sv_maxclients 16 +skill 3 +map MAP01 +sv_maprotation true

# Game environment variables (GAME_ENV_ prefix is stripped)
GAME_ENV_ZANDRONUM_UID=1000
GAME_ENV_ZANDRONUM_GID=1000

# Idle shutdown — probes Zandronum's launcher protocol (Huffman-coded).
# Verified against a live server. The probe reports the server's query flood
# protection (sv_queryignoretime) as "unknown", never as "empty", so a
# rate-limited reply can never be mistaken for an empty server.
ENABLE_IDLE_SHUTDOWN=true
IDLE_CHECK_METHOD=zandronum
IDLE_TIMEOUT_MINUTES=30

# Secrets — rcon password injected as an ECS secret; the shim writes it into a
# config the server +execs, keeping it off the command line. Set it first:
#   pnpm respawn -> Secrets -> doom2
SECRET_REFS=RCON_PASSWORD=sm:respawn/doom2/rcon
REQUIRED_ENV_VARS=RCON_PASSWORD

# rcon-control sidecar — Zandronum rcon (Huffman/salted-MD5) over loopback, on
# the game's UDP port. Reachable only via ECS Exec.
ENABLE_RCON_CONTROL=true
# READ transport: the Zandronum launcher port. Unauthenticated, and the ONLY way
# to see a roster — zandronum rcon runs commands but reports no players.
RCON_PROTOCOL=zandronum-query
RCON_PORT=10666
# WRITE transport: zandronum rcon on the same port (password-only, no username).
RCON_WRITE_PROTOCOL=zandronum
RCON_WRITE_PORT=10666
RCON_WRITE_PASSWORD_VAR=RCON_PASSWORD

# Update checks — `pnpm respawn:check-updates` compares these against the
# values recorded at the last deploy (SSM: /respawn/<svc>/state/...).
# Game files are your own WAD on EFS; only the image can change.
UPDATE_CHECK=build
