# --- Respawn: Garry's Mod Server ---

# Service identity
SERVICE_NAME=gmod
SERVICE_DISPLAY_NAME="Garry's Mod Server"

# Image: built locally from this app's Dockerfile (LinuxGSM gmod + Respawn shim).
# IMAGE_URI is intentionally unset so the deploy builds the wrapper image — the
# upstream image has no env-var config, so respawn-init.sh writes gmodserver.cfg
# from the env vars below before handing off to the upstream entrypoint.
# (Source/srcds, Steam app ID 4020.)

# Container resources — sized for the heaviest selectable gamemode (DarkRP).
# Sandbox / TTT / Prop Hunt use less; deploy-time gamemode selection (below) does
# not change the task size, so this is provisioned for the worst case.
CPU=2048
MEMORY=4096

# Primary port (game traffic + A2S query, UDP)
CONTAINER_PORT=27015
HOST_PORT=27015
PROTOCOL=UDP
# RCON (27015/tcp) and client port (27005/udp). Add 27020/udp if SourceTV is enabled.
ADDITIONAL_PORTS=27015/tcp,27005/udp

# Persistent storage (EFS) — LinuxGSM stores everything under /data: serverfiles
# (SteamCMD install, ~addons/maps/gamemodes), config-lgsm, and logs. Required, or
# the multi-GB SteamCMD install re-runs on every restart. /data is confirmed from
# the image (LGSM_SERVERFILES=/data/serverfiles, LGSM_CONFIG=/data/config-lgsm).
ENABLE_PERSISTENT_STORAGE=true
PERSISTENT_MOUNT_PATH=/data

# Idle shutdown — scales the service to 0 after N idle minutes to save cost.

ENABLE_IDLE_SHUTDOWN=true
# GoldSrc/Source serve every client from one unconnected UDP socket, so the
# netstat check never sees players. Ask the game instead (A2S_INFO).
IDLE_CHECK_METHOD=a2s
IDLE_TIMEOUT_MINUTES=30

# Gamemode — chosen at deploy time via the CLI per-service prompt (AGENT_PROMPT.md §2).
# The chosen value overrides GAME_ENV_GAMEMODE below; in non-interactive/CI deploys
# the prompt is skipped and GAME_ENV_GAMEMODE is used.
DEPLOY_PROMPTS=GAMEMODE:select:ttt|prop_hunt|darkrp

# Secrets — injected as ECS secrets, not plaintext (AGENT_PROMPT.md §7).
# respawn-init.sh reads RCON_PASSWORD -> server.cfg rcon_password (kept off the
# command line) and GSLT -> LinuxGSM gslt -> +sv_setsteamaccount.
#
# Every entry below is resolved by the ECS agent before the container starts, so
# each referenced secret must already exist — a missing one stops the task with
# ResourceInitializationError. Set the values first:  pnpm respawn -> Secrets
#
# This server runs PRIVATE/UNLISTED, so there is no GSLT entry: the shim defaults
# GSLT to empty, which drops +sv_setsteamaccount (matching LinuxGSM's own default).
# To list it publicly, get a Game Server Login Token from
#   https://steamcommunity.com/dev/managegameservers  (use AppID 4020 for GMod)
# store it with `pnpm respawn -> Secrets -> gmod -> GSLT`, then append:
#   ,GSLT=ssm:/respawn/gmod/gslt
SECRET_REFS=RCON_PASSWORD=sm:respawn/gmod/rcon

# Required values — checked at deploy time (preflight), before any image build
# or CloudFormation call.
REQUIRED_ENV_VARS=RCON_PASSWORD,GAMEMODE

# --- Game-specific environment variables (GAME_ENV_ prefix is stripped) ---
# These names are consumed by respawn-init.sh and mapped to LinuxGSM config:
#   GAMEMODE -> gamemode, SERVERNAME -> +hostname, MAP -> defaultmap,
#   MAXPLAYERS -> maxplayers, WORKSHOP_COLLECTION -> wscollectionid.
GAME_ENV_GAMEMODE=ttt
GAME_ENV_SERVERNAME="Respawn Garry's Mod"
GAME_ENV_MAP=gm_construct
GAME_ENV_MAXPLAYERS=16
# Workshop collection ID for addons (optional)
# GAME_ENV_WORKSHOP_COLLECTION=


# Update checks — `pnpm respawn:check-updates` compares these against the
# values recorded at the last deploy (SSM: /respawn/<svc>/state/...).
# LinuxGSM installs GMod via SteamCMD onto EFS at container start.
UPDATE_CHECK=build,steam:4020

# AWS
AWS_REGION=us-east-1
AWS_PROFILE=respawn
