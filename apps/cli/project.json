{
  "name": "cli",
  "projectType": "application",
  "sourceRoot": "apps/cli/src",
  "tags": ["type:app", "lang:ts"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "dependsOn": ["^build"],
      "cache": true,
      "options": {
        "command": "npx tsdown",
        "cwd": "{projectRoot}"
      }
    }
  }
}
