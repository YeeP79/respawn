# --- Respawn: Left 4 Dead 2 Server ---

# Service identity
SERVICE_NAME=l4d2
SERVICE_DISPLAY_NAME="Left 4 Dead 2 Server"

# Image (upstream — no local build needed)
IMAGE_URI=left4devops/l4d2:latest

# Container resources (Source engine — moderate)
CPU=512
MEMORY=2048

# Primary port (game traffic)
CONTAINER_PORT=27015
HOST_PORT=27015
PROTOCOL=UDP
ADDITIONAL_PORTS=27015/tcp

# Game environment variables (GAME_ENV_ prefix is stripped)
GAME_ENV_HOSTNAME=Respawn L4D2
# Starting map (Dead Center campaign)
GAME_ENV_DEFAULT_MAP=c1m1_hotel
# Game mode: coop, versus, realism, survival, scavenge
GAME_ENV_DEFAULT_MODE=coop
# Allowed game types (comma-separated)
GAME_ENV_GAME_TYPES=coop,versus,realism,survival
# Region: 0=US East, 1=US West, 2=South America, 3=Europe, 4=Asia,
#          5=Australia, 6=Middle East, 7=Africa, 255=Worldwide
GAME_ENV_REGION=0
# RCON password — injected as an ECS secret under the same env var name
# the image already reads. Set it with:  pnpm respawn -> Secrets -> l4d2
SECRET_REFS=RCON_PASSWORD=sm:respawn/l4d2/rcon

# Idle shutdown — netstat-based
ENABLE_IDLE_SHUTDOWN=true
IDLE_CHECK_METHOD=netstat
IDLE_TIMEOUT_MINUTES=30

# --- Prerequisites ---
# No game files or tokens needed — the image downloads everything automatically
# via SteamCMD on first start.
#
# --- Addons / Mods ---
# To add custom content, extend the Dockerfile:
#   COPY my_addon /addons/
# Then remove IMAGE_URI from .env so respawn builds from Dockerfile.
# See: https://github.com/Left4DevOps/l4d2-docker
