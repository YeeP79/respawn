# --- Respawn: Team Fortress Classic Server ---

# Service identity
SERVICE_NAME=tfc
SERVICE_DISPLAY_NAME="Team Fortress Classic Server"

# Image: built locally from this app's Dockerfile (jives/hlds:tfc + Respawn shim).
# IMAGE_URI is intentionally unset — the upstream entrypoint forwards args to
# hlds_run without eval (`./hlds_run "-game $GAME $@"`), so a secret cannot be
# referenced on the command line. respawn-init.sh writes tfc/server.cfg instead.

# Container resources
CPU=256
MEMORY=512

# Primary port (game traffic)
CONTAINER_PORT=27015
HOST_PORT=27015
PROTOCOL=UDP
ADDITIONAL_PORTS=26900/udp
# Admin ports — NOT publicly exposed (not a public surface; GoldSrc rcon is via the sidecar).
# Declared on the task (loopback-reachable by the rcon-control sidecar) but
# the security group opens no ingress for them.
INTERNAL_PORTS=27015/tcp

# HLDS is configured via command-line args. Nothing secret goes here — it lands
# in the ECS task definition and in `ps` inside the container. rcon comes from
# SECRET_REFS below and is written to server.cfg by the shim.
CONTAINER_COMMAND=+log on +maxplayers 12 +map ctf_2fort

# Idle shutdown — scales the service to 0 after N idle minutes to save cost.
ENABLE_IDLE_SHUTDOWN=true
# GoldSrc/Source serve every client from one unconnected UDP socket, so the
# netstat check never sees players. Ask the game instead (A2S_INFO).
IDLE_CHECK_METHOD=a2s
IDLE_TIMEOUT_MINUTES=30

# Secrets — injected as ECS secrets, not plaintext (AGENT_PROMPT.md §7).
# respawn-init.sh reads RCON_PASSWORD and writes it into tfc/server.cfg, which
# GoldSrc execs at map start. Resolved by the ECS agent before the container
# starts, so set the value first:  pnpm respawn -> Secrets -> tfc
SECRET_REFS=RCON_PASSWORD=sm:respawn/tfc/rcon

# --- Game-specific environment variables (GAME_ENV_ prefix is stripped) ---
# Consumed by respawn-init.sh: SERVERNAME -> hostname.
GAME_ENV_SERVERNAME="Respawn TFC"

# Update checks — `pnpm respawn:check-updates` compares these against the
# values recorded at the last deploy (SSM: /respawn/<svc>/state/...).
# jives/hlds bakes the game files into the image (see cs16).
UPDATE_CHECK=build
