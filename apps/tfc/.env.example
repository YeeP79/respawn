# --- Respawn: Team Fortress Classic Server ---

# Service identity
SERVICE_NAME=tfc
SERVICE_DISPLAY_NAME="Team Fortress Classic Server"

# Image (upstream — no local build needed)
IMAGE_URI=jives/hlds:tfc

# Container resources
CPU=256
MEMORY=512

# Primary port (game traffic)
CONTAINER_PORT=27015
HOST_PORT=27015
PROTOCOL=UDP
ADDITIONAL_PORTS=27015/tcp,26900/udp

# Container command override (HLDS uses command-line args for config)
CONTAINER_COMMAND=+log on +rcon_password changeme +maxplayers 12 +map ctf_2fort

# Idle shutdown — netstat-based (no HTTP endpoint)
ENABLE_IDLE_SHUTDOWN=true
IDLE_CHECK_METHOD=netstat
IDLE_TIMEOUT_MINUTES=30
