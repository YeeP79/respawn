# --- Respawn: Unreal Tournament 99 Server ---

# Service identity
SERVICE_NAME=ut99
SERVICE_DISPLAY_NAME="Unreal Tournament 99 Server"

# Image (upstream — no local build needed)
IMAGE_URI=roemer/ut99-server:latest

# Container resources
CPU=512
MEMORY=1024

# Primary port (game traffic)
CONTAINER_PORT=7777
HOST_PORT=7777
PROTOCOL=UDP
ADDITIONAL_PORTS=7778/udp,7779/udp,7780/udp,7781/udp,8777/udp
# Admin ports — NOT publicly exposed (UnrealAdmin web server; admin only).
# Declared on the task (loopback-reachable by the rcon-control sidecar) but
# the security group opens no ingress for them.
INTERNAL_PORTS=5580/tcp

# Idle shutdown — netstat-based (no HTTP endpoint)
ENABLE_IDLE_SHUTDOWN=true
# Unreal Engine 1 answers GameSpy queries on the game port + 1 (7778).
IDLE_CHECK_METHOD=gamespy
IDLE_QUERY_PORT=7778
IDLE_TIMEOUT_MINUTES=30

# Admin password — injected as an ECS secret, not plaintext (see AGENT_PROMPT.md §7).
# Set the value with the Secrets CLI action, then reference it here:
# Two different passwords, and the names are not interchangeable:
#   UT_ADMINPWD     -> [Engine.GameInfo] AdminPassword        (in-game `admin login`)
#   UT_WEBADMINPWD  -> [UTServerAdmin.UTServerAdmin] AdminPassword (UWeb on 5580)
# Set only the first and the web admin silently keeps the image's baked-in default of
# admin/admin. It is loopback-only (INTERNAL_PORTS, no ingress), but one typo moving
# 5580 to ADDITIONAL_PORTS would publish an unauthenticated remote admin console.
SECRET_REFS=UT_ADMINPWD=sm:respawn/ut99/admin-pwd,UT_WEBADMINPWD=sm:respawn/ut99/admin-pwd

# rcon-control sidecar. UT99 has no rcon: the sidecar speaks GameSpy v1 to the query
# port (game port + 1), which is read-only and unauthenticated. RCON_PASSWORD_VAR
# points at an existing secret purely to satisfy the loader's "rcon needs a secret"
# check — gamespy never reads it, and `query` is the only tool this enables.
ENABLE_RCON_CONTROL=true
RCON_PROTOCOL=gamespy
RCON_PORT=7778
RCON_PASSWORD_VAR=UT_ADMINPWD

# --- Game-specific environment variables ---
GAME_ENV_UT_SERVERNAME="Respawn UT99"
GAME_ENV_UT_SERVERURL=CTF-Face?game=BotPack.CTFGame

# Do NOT announce this server to the public master-server lists. Stock UT99 uplinks
# to twelve of them on boot (utmaster.epicgames.com, master.oldunreal.com, ...), which
# publishes the server's address to anyone browsing. `-lanplay` does not stop it.
#
# This disables only `IpServer.UdpServerUplink`. The separate `IpServer.UdpServerQuery`
# ServerActor still answers GameSpy on the query port, which is what the idle-shutdown
# watchdog probes — verified: with DoUpLink=False the log shows zero "Master Server is"
# lines and `\info\` still replies. Flip to True to list the server publicly.
GAME_ENV_UT_DOUPLINK=False
GAME_ENV_UT_MAXPLAYERS=16

# Update checks — `pnpm respawn:check-updates` compares these against the
# values recorded at the last deploy (SSM: /respawn/<svc>/state/...).
# Only the image can change.
UPDATE_CHECK=image
