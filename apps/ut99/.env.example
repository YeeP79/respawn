# --- Respawn: Unreal Tournament 99 Server ---

# Service identity
SERVICE_NAME=ut99
SERVICE_DISPLAY_NAME="Unreal Tournament 99 Server"

# Image (upstream — no local build needed)
IMAGE_URI=roemer/ut99-server:latest

# Container resources
CPU=512
MEMORY=1024

# Primary port (game traffic)
CONTAINER_PORT=7777
HOST_PORT=7777
PROTOCOL=UDP
ADDITIONAL_PORTS=7778/udp,7779/udp,7780/udp,7781/udp,8777/udp,5580/tcp

# Idle shutdown — netstat-based (no HTTP endpoint)
ENABLE_IDLE_SHUTDOWN=true
# Unreal Engine 1 answers GameSpy queries on the game port + 1 (7778).
IDLE_CHECK_METHOD=gamespy
IDLE_QUERY_PORT=7778
IDLE_TIMEOUT_MINUTES=30

# Admin password — injected as an ECS secret, not plaintext (see AGENT_PROMPT.md §7).
# Set the value with the Secrets CLI action, then reference it here:
SECRET_REFS=UT_ADMINPWD=sm:respawn/ut99/admin-pwd

# --- Game-specific environment variables ---
GAME_ENV_UT_SERVERNAME="Respawn UT99"
GAME_ENV_UT_SERVERURL=CTF-Face?game=BotPack.CTFGame
GAME_ENV_UT_MAXPLAYERS=16
