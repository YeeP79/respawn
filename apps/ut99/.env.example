# --- Respawn: Unreal Tournament 99 — shared base (all variants) ---
# Tracked template for apps/ut99/.env. Values common to every ut99 variant; each
# variants/<v>/.env layers its own identity, image, secrets and game-env over this
# (the overlay wins on a collision). Copy to `.env` on a fresh clone.

# Container resources
CPU=512
MEMORY=1024

# Primary port (game traffic) — the same for any UT99 image.
CONTAINER_PORT=7777
HOST_PORT=7777
PROTOCOL=UDP
ADDITIONAL_PORTS=7778/udp,7779/udp,7780/udp,7781/udp,8777/udp
# Admin port — loopback only (rcon-control sidecar reaches it); no public ingress.
INTERNAL_PORTS=5580/tcp

# Idle shutdown — UE1 answers GameSpy queries on the game port + 1 (7778).
ENABLE_IDLE_SHUTDOWN=true
IDLE_CHECK_METHOD=gamespy
IDLE_QUERY_PORT=7778
IDLE_TIMEOUT_MINUTES=30

# rcon-control READ transport — GameSpy v1 on the query port (read-only, standard for
# any UT99 image). The optional WRITE transport (a UWeb admin console, if the image
# ships one) is declared per variant.
ENABLE_RCON_CONTROL=true
RCON_PROTOCOL=gamespy
RCON_PORT=7778

# Update checks — `pnpm respawn:check-updates` compares against the last deploy
# (SSM: /respawn/<svc>/state/...). Only the image can change.
UPDATE_CHECK=image

# AWS
AWS_ACCOUNT_ID=847378615943
AWS_REGION=us-east-1
AWS_PROFILE=respawn
