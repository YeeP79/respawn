# --- Respawn: UT99 "vanilla" variant (bymatej/ut99-server, stock + bonus packs) ---
# Tracked template for apps/ut99/variants/vanilla/.env. Layers over apps/ut99/.env
# (shared base). Stock UT99 — no third-party mods; only the official Epic bonus packs.

# Service identity — a distinct service from the modded `ut99` (its own stack, cluster,
# ECR repo, and secrets). Named with a suffix so both can coexist.
SERVICE_NAME=ut99-vanilla
SERVICE_DISPLAY_NAME="Unreal Tournament 99 (Vanilla)"

# Image — a different lineage (original linux 436 server + the four bonus packs +
# UTPGPatch451). Exposes the same UT_* env interface and a UWeb admin console on 5580 as
# the modded build, so the write transport works identically — but it ships NO mod
# gametypes (no MonsterHunt/ChaosUT/BunnyTrack) and no gameplay mutators.
IMAGE_URI=bymatej/ut99-server:latest

# Admin passwords — injected as ECS secrets, never plaintext. Own secret path so vanilla
# and modded don't share credentials. Create these before the first deploy.
#   UT_ADMINPWD     -> in-game admin password
#   UT_WEBADMINPWD  -> UWeb console (5580) password
SECRET_REFS=UT_ADMINPWD=sm:respawn/ut99-vanilla/admin-pwd,UT_WEBADMINPWD=sm:respawn/ut99-vanilla/admin-pwd
RCON_PASSWORD_VAR=UT_ADMINPWD

# rcon-control WRITE transport — the UWeb admin console on 5580 (HTTP Basic auth). The
# MCP routes run_command / set_cvar / rcon here; queries stay on the gamespy read path.
RCON_WRITE_PROTOCOL=uweb
RCON_WRITE_PORT=5580
RCON_WRITE_PASSWORD_VAR=UT_WEBADMINPWD
RCON_WRITE_USER=admin

# --- Game-specific environment variables ---
GAME_ENV_UT_SERVERNAME="Respawn UT99 (Vanilla)"
# No mutators in the URL → the server runs genuinely stock (rules report mutators=None).
GAME_ENV_UT_SERVERURL=CTF-Face?game=BotPack.CTFGame
GAME_ENV_UT_MAXPLAYERS=16
# Do NOT announce to the public master-server lists; the query port still answers GameSpy.
GAME_ENV_UT_DOUPLINK=False
# Web admin username; must match RCON_WRITE_USER. Password is the UT_WEBADMINPWD secret.
GAME_ENV_UT_WEBADMINUSER=admin
