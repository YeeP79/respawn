# --- Respawn: UT99 "modded" variant (roemer/ut99-server, full mod set) ---
# Tracked template for apps/ut99/variants/modded/.env. Layers over apps/ut99/.env
# (shared base) — only the deltas that make this the modded build live here.

# Service identity — bare `ut99` keeps the deployed stack / cluster / secret names
# (this is the canonical UT99 server; the vanilla variant is `ut99-vanilla`).
SERVICE_NAME=ut99
SERVICE_DISPLAY_NAME="Unreal Tournament 99 (Modded)"

# Image (upstream — no local build needed). Works because the image reads its config
# from env vars. This build bakes in MonsterHunt, ChaosUT, BunnyTrack, MapVote,
# ZeroPing, StrangeLove, CustomCrossHairScale, ... — catalogued in rcon-manifest.json
# under `modData`.
IMAGE_URI=roemer/ut99-server:latest

# Admin passwords — injected as ECS secrets, not plaintext (see AGENT_PROMPT.md §7).
# Two DIFFERENT passwords; the names are not interchangeable:
#   UT_ADMINPWD     -> [Engine.GameInfo] AdminPassword            (in-game `admin login`)
#   UT_WEBADMINPWD  -> [UTServerAdmin.UTServerAdmin] AdminPassword (UWeb console on 5580)
# Set only the first and the web admin silently keeps the image's baked-in default of
# admin/admin. It is loopback-only (INTERNAL_PORTS, base .env), but one typo moving
# 5580 to ADDITIONAL_PORTS would publish an unauthenticated remote admin console.
SECRET_REFS=UT_ADMINPWD=sm:respawn/ut99/admin-pwd,UT_WEBADMINPWD=sm:respawn/ut99/admin-pwd
# The gamespy read transport takes no credentials; RCON_PASSWORD_VAR only satisfies
# the loader's "rcon needs a secret" check. Points at an existing secret.
RCON_PASSWORD_VAR=UT_ADMINPWD

# rcon-control WRITE transport — the UWeb admin console on 5580 (HTTP Basic auth), the
# same command interpreter an in-game admin reaches after `adminlogin`. The MCP routes
# run_command / set_cvar / rcon here; queries stay on the gamespy read path (base .env).
# RCON_WRITE_PASSWORD_VAR must name a SECRET_REFS entry (never plaintext); RCON_WRITE_USER
# must match the webadmin username (GAME_ENV_UT_WEBADMINUSER below).
RCON_WRITE_PROTOCOL=uweb
RCON_WRITE_PORT=5580
RCON_WRITE_PASSWORD_VAR=UT_WEBADMINPWD
RCON_WRITE_USER=admin

# --- Game-specific environment variables ---
GAME_ENV_UT_SERVERNAME="Respawn UT99"
GAME_ENV_UT_SERVERURL=CTF-Face?game=BotPack.CTFGame
GAME_ENV_UT_MAXPLAYERS=16

# Do NOT announce this server to the public master-server lists. Stock UT99 uplinks to
# twelve of them on boot (utmaster.epicgames.com, master.oldunreal.com, ...), which
# publishes the server's address to anyone browsing. `-lanplay` does not stop it. This
# disables only IpServer.UdpServerUplink; IpServer.UdpServerQuery still answers GameSpy
# on the query port (what the idle-shutdown watchdog probes). Flip to True to list publicly.
GAME_ENV_UT_DOUPLINK=False
# Web admin username; must match RCON_WRITE_USER. Password is the UT_WEBADMINPWD secret.
# Left unset, the image defaults the username to "admin".
GAME_ENV_UT_WEBADMINUSER=admin
