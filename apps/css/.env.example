# --- Respawn: Counter-Strike: Source Server ---

# Service identity
SERVICE_NAME=css
SERVICE_DISPLAY_NAME="Counter-Strike: Source Server"

# Image: built locally from this app's Dockerfile (LinuxGSM css + Respawn shim).
# IMAGE_URI is intentionally unset — the upstream image has no env-var config, so
# respawn-init.sh writes cssserver.cfg + server.cfg from the env vars below before
# handing off to the upstream entrypoint. Source engine, game dir "cstrike".

# Container resources (1 vCPU / 2 GB — Source 1 is much lighter than CS2)
CPU=1024
MEMORY=2048

# Primary port (game traffic + query, UDP)
CONTAINER_PORT=27015
HOST_PORT=27015
PROTOCOL=UDP
# RCON (27015/tcp), client port (27005/udp), SourceTV (27020/udp)
ADDITIONAL_PORTS=27015/tcp,27005/udp,27020/udp

# Persistent storage (EFS) — LinuxGSM keeps serverfiles/config/logs under /data.
# Required, or the SteamCMD install re-downloads on every cold start (incl. every
# idle-shutdown wake).
ENABLE_PERSISTENT_STORAGE=true
PERSISTENT_MOUNT_PATH=/data

# Idle shutdown — scales the service to 0 after N idle minutes to save cost.
# CS:S query is UDP, so use netstat on 27015 (http mode does not apply).
ENABLE_IDLE_SHUTDOWN=true
IDLE_CHECK_METHOD=netstat
IDLE_TIMEOUT_MINUTES=30

# Secrets — injected as ECS secrets, not plaintext (AGENT_PROMPT.md §7).
# respawn-init.sh writes RCON_PASSWORD into a custom server.cfg (kept off the
# command line) and maps GSLT -> LinuxGSM gslt -> +sv_setsteamaccount.
#
# Every entry below is resolved by the ECS agent before the container starts, so
# each referenced secret must already exist — a missing one stops the task with
# ResourceInitializationError. Create them with the Secrets CLI action first.
#
# This server runs PRIVATE/UNLISTED, so there is no GSLT entry: the shim defaults
# GSLT to empty, which drops +sv_setsteamaccount (matching LinuxGSM's own default).
#
# To list it publicly, get a Game Server Login Token from
#   https://steamcommunity.com/dev/managegameservers  (use AppID 240 for CS:S)
# store it with `pnpm respawn -> Secrets -> css -> GSLT`, then append:
#   ,GSLT=ssm:/respawn/css/gslt
SECRET_REFS=RCON_PASSWORD=sm:respawn/css/rcon

# Required values — checked at deploy time (preflight).
REQUIRED_ENV_VARS=RCON_PASSWORD

# --- Game-specific environment variables (GAME_ENV_ prefix is stripped) ---
# Consumed by respawn-init.sh: SERVERNAME -> hostname, MAP -> defaultmap,
# MAXPLAYERS -> maxplayers.
GAME_ENV_SERVERNAME="Respawn CS:Source"
GAME_ENV_MAP=de_dust2
GAME_ENV_MAXPLAYERS=16

# AWS
AWS_REGION=us-east-1
AWS_PROFILE=respawn
