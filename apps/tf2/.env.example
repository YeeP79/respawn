# --- Respawn: Team Fortress 2 Server ---

# Service identity
SERVICE_NAME=tf2
SERVICE_DISPLAY_NAME="Team Fortress 2 Server"

# Image (upstream — no local build needed)
IMAGE_URI=cm2network/tf2:latest

# Container resources (1 vCPU, 2 GB — appropriate for 14-24 players at 66 tick)
CPU=1024
MEMORY=2048

# Primary port (game traffic)
CONTAINER_PORT=27015
HOST_PORT=27015
PROTOCOL=UDP
ADDITIONAL_PORTS=27015/tcp,27020/udp

# Game environment variables (GAME_ENV_ prefix is stripped)
# SRCDS_TOKEN is required for the server to be publicly listed.
# Generate one at https://steamcommunity.com/dev/managegameservers using AppID 440.
GAME_ENV_SRCDS_TOKEN=changeme
GAME_ENV_SRCDS_HOSTNAME=Respawn TF2
GAME_ENV_SRCDS_STARTMAP=ctf_2fort
GAME_ENV_SRCDS_MAXPLAYERS=24
GAME_ENV_SRCDS_TICKRATE=66
GAME_ENV_SRCDS_RCONPW=changeme
GAME_ENV_SRCDS_PORT=27015
GAME_ENV_SRCDS_TV_PORT=27020

# Idle shutdown — netstat-based (no HTTP endpoint)
ENABLE_IDLE_SHUTDOWN=true
IDLE_CHECK_METHOD=netstat
IDLE_TIMEOUT_MINUTES=30
