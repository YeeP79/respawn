# --- Respawn: Team Fortress 2 Server ---

# Service identity
SERVICE_NAME=tf2
SERVICE_DISPLAY_NAME="Team Fortress 2 Server"

# Image (upstream — no local build needed)
IMAGE_URI=cm2network/tf2:latest

# Container resources (1 vCPU, 2 GB — appropriate for 14-24 players at 66 tick)
CPU=1024
MEMORY=2048

# Primary port (game traffic)
CONTAINER_PORT=27015
HOST_PORT=27015
PROTOCOL=UDP
ADDITIONAL_PORTS=27020/udp
# Admin ports — NOT publicly exposed (Source RCON; sidecar reaches it over loopback).
# Declared on the task (loopback-reachable by the rcon-control sidecar) but
# the security group opens no ingress for them.
INTERNAL_PORTS=27015/tcp

# Game environment variables (GAME_ENV_ prefix is stripped)
GAME_ENV_SRCDS_HOSTNAME=Respawn TF2
GAME_ENV_SRCDS_STARTMAP=ctf_2fort
GAME_ENV_SRCDS_MAXPLAYERS=24
GAME_ENV_SRCDS_TICKRATE=66
GAME_ENV_SRCDS_PORT=27015
GAME_ENV_SRCDS_TV_PORT=27020

# Secrets — injected as ECS secrets, not plaintext (AGENT_PROMPT.md §7).
# Both names are read directly by the cm2network/tf2 image. Every entry here is
# resolved by the ECS agent before the container starts, so the secret must
# already exist:  pnpm respawn -> Secrets -> tf2
#
# This server runs UNLISTED: there is no SRCDS_TOKEN entry. To list it publicly,
# generate a Game Server Login Token for AppID 440 at
# https://steamcommunity.com/dev/managegameservers, store it, then append:
#   ,SRCDS_TOKEN=ssm:/respawn/tf2/gslt
SECRET_REFS=SRCDS_RCONPW=sm:respawn/tf2/rcon

# Idle shutdown — scales the service to 0 after N idle minutes to save cost.
ENABLE_IDLE_SHUTDOWN=true
# GoldSrc/Source serve every client from one unconnected UDP socket, so the
# netstat check never sees players. Ask the game instead (A2S_INFO).
IDLE_CHECK_METHOD=a2s
IDLE_TIMEOUT_MINUTES=30

# Update checks — `pnpm respawn:check-updates` compares these against the
# values recorded at the last deploy (SSM: /respawn/<svc>/state/...).
# cm2network installs TF2 via SteamCMD at container start.
UPDATE_CHECK=image,steam:232250
