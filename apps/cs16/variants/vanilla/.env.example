# cs16 / vanilla — the stock Counter-Strike 1.6 server (jives/hlds, no mods).
#
# This is the CANONICAL variant, so it keeps the bare project name: SERVICE_NAME=cs16.
# That is what pins its identity — stack `respawn-dev-cs16`, ECR repo `respawn/cs16`.
# Do NOT rename it; a sibling variant takes a suffix instead (see ../ffa).
#
# Layered over ../../.env (the base). Anything set here WINS over the base, so the base
# holds what every cs16 variant shares (ports, sizing, idle, AWS) and this file holds
# only the deltas that make a build what it is.
SERVICE_NAME=cs16
SERVICE_DISPLAY_NAME="Counter-Strike 1.6 Server"

# Passed straight to hlds_run (NOT eval'd upstream), so a secret can never go here —
# it would also be visible in `ps` inside the container. Secrets go in SECRET_REFS and
# are written into server.cfg by respawn-init.sh.
CONTAINER_COMMAND=+log on +maxplayers 16 +map de_dust2 +sv_lan 0

# Injected as ECS secrets, never plaintext in the task definition. The shim writes them
# into cstrike/server.cfg at boot.
#
# Optional join password (sv_password): add SERVER_PASSWORD to make players enter a
# password to connect. Leave it out entirely for an open server — an empty value is NOT
# the same as absent, and a referenced-but-missing secret fails the task with
# ResourceInitializationError.
#   SECRET_REFS=RCON_PASSWORD=sm:respawn/cs16/rcon,SERVER_PASSWORD=sm:respawn/cs16/serverpw
SECRET_REFS=RCON_PASSWORD=sm:respawn/cs16/rcon

# Consumed by respawn-init.sh: SERVERNAME -> hostname.
GAME_ENV_SERVERNAME="Respawn CS 1.6"

# respawn-init.sh bakes sane networking defaults into server.cfg (sv_maxupdaterate 101
# etc.) — GoldSrc's stock 30 causes "had to click twice to fire". Override if needed:
#   GAME_ENV_SV_MAXUPDATERATE=101
