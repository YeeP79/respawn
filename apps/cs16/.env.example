# --- Respawn: Counter-Strike 1.6 — BASE config, shared by every variant ---
#
# cs16 is a VARIANT project: it is represented only by apps/cs16/variants/*, never by
# this directory. Each variant layers its own .env over this one and WINS on a key
# collision, so what lives here is strictly what every cs16 build shares — ports,
# sizing, idle policy, rcon transport, AWS. Anything that makes a build what it *is*
# (SERVICE_NAME, image, CONTAINER_COMMAND, SECRET_REFS) belongs in the variant.
#
# Variants:
#   variants/vanilla -> SERVICE_NAME=cs16      stock jives/hlds (the canonical build)
#   variants/ffa     -> SERVICE_NAME=cs16-ffa  PLANNED, not yet built. CSDM free-for-all;
#                       blocked on a mod-capable base image. Read FFA-DEATHMATCH.md first —
#                       the layout is now a pure drop-in, but jives/hlds cannot load Metamod.
#
# Nothing deploys from this file alone. Copy it AND a variant's:
#   cp apps/cs16/.env.example apps/cs16/.env
#   cp apps/cs16/variants/vanilla/.env.example apps/cs16/variants/vanilla/.env

# Container resources (GoldSrc is extremely light)
CPU=256
MEMORY=512

# Primary port (game traffic)
CONTAINER_PORT=27015
HOST_PORT=27015
PROTOCOL=UDP
ADDITIONAL_PORTS=26900/udp
# Admin ports — NOT publicly exposed (not a public surface; GoldSrc rcon is via the sidecar).
# Declared on the task (loopback-reachable by the rcon-control sidecar) but
# the security group opens no ingress for them.
INTERNAL_PORTS=27015/tcp

# Idle shutdown — scales the service to 0 after N idle minutes to save cost.
ENABLE_IDLE_SHUTDOWN=true
# GoldSrc/Source serve every client from one unconnected UDP socket, so the
# netstat check never sees players. Ask the game instead (A2S_INFO).
IDLE_CHECK_METHOD=a2s
IDLE_TIMEOUT_MINUTES=30

# rcon-control sidecar — reachable ONLY via `aws ecs execute-command` (SSM), no
# inbound port. It runs rcon over loopback so the password never leaves the task.
# GoldSrc rcon rides UDP on the game port. Requires the variant's rcon password.
ENABLE_RCON_CONTROL=true
RCON_PROTOCOL=goldsrc

# Update checks — `pnpm respawn:check-updates` compares these against the
# values recorded at the last deploy (SSM: /respawn/<svc>/state/...).
# jives/hlds bakes the game files into the image, so a game update
# arrives as a new base digest — which the build hash already catches.
UPDATE_CHECK=build

# AWS
AWS_ACCOUNT_ID=847378615943
AWS_REGION=us-east-1
AWS_PROFILE=respawn
