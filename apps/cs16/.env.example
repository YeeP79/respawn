# --- Respawn: Counter-Strike 1.6 Server ---

# Service identity
SERVICE_NAME=cs16
SERVICE_DISPLAY_NAME="Counter-Strike 1.6 Server"

# Image: built locally from this app's Dockerfile (jives/hlds:cstrike + Respawn shim).
# IMAGE_URI is intentionally unset — the upstream entrypoint forwards args to
# hlds_run without eval (`./hlds_run "-game $GAME $@"`), so a secret cannot be
# referenced on the command line. respawn-init.sh writes cstrike/server.cfg from
# the injected env vars instead. GoldSrc/HLDS, same family as tfc.

# Container resources (GoldSrc is extremely light)
CPU=256
MEMORY=512

# Primary port (game traffic)
CONTAINER_PORT=27015
HOST_PORT=27015
PROTOCOL=UDP
ADDITIONAL_PORTS=27015/tcp,26900/udp

# HLDS is configured via command-line args. Nothing secret goes here — it lands
# in the ECS task definition and in `ps` inside the container. rcon comes from
# SECRET_REFS below and is written to server.cfg by the shim.
CONTAINER_COMMAND=+log on +maxplayers 16 +map de_dust2 +sv_lan 0

# Idle shutdown — scales the service to 0 after N idle minutes to save cost.
ENABLE_IDLE_SHUTDOWN=true
# GoldSrc/Source serve every client from one unconnected UDP socket, so the
# netstat check never sees players. Ask the game instead (A2S_INFO).
IDLE_CHECK_METHOD=a2s
IDLE_TIMEOUT_MINUTES=30

# Secrets — injected as ECS secrets, not plaintext (AGENT_PROMPT.md §7).
# respawn-init.sh reads RCON_PASSWORD and writes it into cstrike/server.cfg,
# which GoldSrc execs at map start. Every entry here is resolved by the ECS agent
# before the container starts, so a missing secret stops the task with
# ResourceInitializationError. Set the value first:  respawn secrets
#
# GoldSrc has no GSLT, so there is nothing else to store.
SECRET_REFS=RCON_PASSWORD=sm:respawn/cs16/rcon

# rcon-control sidecar — reachable ONLY via `aws ecs execute-command` (SSM), no
# inbound port. It runs rcon over loopback so the password never leaves the task.
# GoldSrc rcon rides UDP on the game port. Requires the rcon password above.
ENABLE_RCON_CONTROL=true
RCON_PROTOCOL=goldsrc

# --- Game-specific environment variables (GAME_ENV_ prefix is stripped) ---
# Consumed by respawn-init.sh: SERVERNAME -> hostname.
GAME_ENV_SERVERNAME="Respawn CS 1.6"


# Update checks — `pnpm respawn:check-updates` compares these against the
# values recorded at the last deploy (SSM: /respawn/<svc>/state/...).
# jives/hlds bakes the game files into the image, so a game update
# arrives as a new base digest — which the build hash already catches.
UPDATE_CHECK=build

# AWS
AWS_ACCOUNT_ID=847378615943
AWS_REGION=us-east-1
AWS_PROFILE=respawn
