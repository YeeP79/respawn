# --- Respawn: Valheim Server ---

# Service identity
SERVICE_NAME=valheim
SERVICE_DISPLAY_NAME="Valheim Server"

# Image (upstream — no local build needed)
IMAGE_URI=ghcr.io/lloesche/valheim-server:latest

# Container resources
CPU=1024
MEMORY=4096

# Primary port (game traffic)
CONTAINER_PORT=2456
HOST_PORT=2456
PROTOCOL=UDP
ADDITIONAL_PORTS=2457/udp,2458/udp

# Persistent storage (world data + backups)
ENABLE_PERSISTENT_STORAGE=true
PERSISTENT_MOUNT_PATH=/config

# Idle shutdown — uses built-in HTTP status endpoint
ENABLE_IDLE_SHUTDOWN=true
IDLE_CHECK_METHOD=http
IDLE_STATUS_ENDPOINT=http://localhost/status.json
IDLE_TIMEOUT_MINUTES=30

# Server password — injected as an ECS secret, not plaintext (see AGENT_PROMPT.md §7).
# Set the value with the Secrets CLI action, then reference it here:
SECRET_REFS=SERVER_PASS=sm:respawn/valheim/server-pass

# --- Game-specific environment variables ---
# These are passed to the container as-is (GAME_ENV_ prefix stripped)
GAME_ENV_SERVER_NAME="Respawn Valheim"
GAME_ENV_WORLD_NAME=Respawn
GAME_ENV_SERVER_PORT=2456
GAME_ENV_STATUS_HTTP=true
GAME_ENV_BACKUPS=true
GAME_ENV_UPDATE_CRON=*/15 * * * *

# Required values — checked at deploy time (preflight). SERVER_PASS comes from
# SECRET_REFS above, so this only guards against the ref being removed.
REQUIRED_ENV_VARS=SERVER_PASS

# Update checks — `pnpm respawn:check-updates` compares these against the
# values recorded at the last deploy (SSM: /respawn/<svc>/state/...).
# lloesche installs Valheim via SteamCMD at container start.
UPDATE_CHECK=image,steam:896660
